import os
import time
import subprocess
import signal
import logging
from datetime import datetime

# ================= 配置区 =================
CHECK_INTERVAL = 30           # 每次检查的间隔时间（秒）
STUCK_TIMEOUT = 600           # 持续卡住多久后触发重启（秒），10分钟 = 600秒
POWER_THRESHOLD = 150         # 功耗阈值（瓦）
VRAM_THRESHOLD = 1000         # 显存占用阈值（MB），过滤掉系统进程，假设大于1000MB视为有任务占用
RESTART_CMD = "bash qwen3-1.7b-base_openr1_data_icl_wokl.sh" 
TARGET_GPU_COUNT = 8          # 预期GPU数量
# ==========================================

logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')

def get_gpu_metrics():
    """获取所有GPU的当前状态 (显存, 利用率, 功耗)"""
    # 提取：索引, 已用显存(MB), 算力利用率(%), 功耗(W)
    cmd = "nvidia-smi --query-gpu=index,memory.used,utilization.gpu,power.draw --format=csv,noheader,nounits"
    try:
        output = subprocess.check_output(cmd, shell=True).decode('utf-8').strip().split('\n')
        metrics = []
        for line in output:
            if not line.strip(): continue
            idx, mem, util, power = [float(x.strip()) for x in line.split(',')]
            metrics.append({'mem': mem, 'util': util, 'power': power})
        return metrics
    except Exception as e:
        logging.error(f"获取GPU状态失败: {e}")
        return []

def is_gpu_stuck(metric):
    """判断单张GPU是否处于僵死状态"""
    # 显存被占用 && (利用率为0 || 功耗低于阈值)
    mem_occupied = metric['mem'] > VRAM_THRESHOLD
    low_usage = (metric['util'] == 0) or (metric['power'] < POWER_THRESHOLD)
    return mem_occupied and low_usage

def kill_gpu_processes():
    """杀掉所有占用GPU的计算进程"""
    logging.warning("正在清理占用 GPU 的僵尸进程...")
    cmd = "nvidia-smi --query-compute-apps=pid --format=csv,noheader"
    try:
        pids = subprocess.check_output(cmd, shell=True).decode('utf-8').strip().split('\n')
        killed_pids = set()
        for pid_str in pids:
            pid = pid_str.strip()
            if pid and pid not in killed_pids:
                try:
                    os.kill(int(pid), signal.SIGKILL)
                    killed_pids.add(pid)
                    logging.info(f"已强制结束 PID: {pid}")
                except ProcessLookupError:
                    pass
    except Exception as e:
        logging.error(f"清理进程时发生异常: {e}")

def main():
    stuck_start_time = None
    
    logging.info("GPU 监控服务已启动...")
    
    while True:
        metrics = get_gpu_metrics()
        
        if len(metrics) != TARGET_GPU_COUNT:
            logging.warning(f"检测到的 GPU 数量 ({len(metrics)}) 与预期 ({TARGET_GPU_COUNT}) 不符，跳过此次检查。")
            time.sleep(CHECK_INTERVAL)
            continue
            
        # 必须 8 张卡全都满足条件才算卡住
        all_stuck = all(is_gpu_stuck(m) for m in metrics)
        
        if all_stuck:
            if stuck_start_time is None:
                stuck_start_time = time.time()
                logging.warning("检测到所有 GPU 进入疑似僵死状态，开始计时...")
            else:
                elapsed = time.time() - stuck_start_time
                logging.info(f"僵死状态已持续 {int(elapsed)} 秒...")
                
                # 如果超过了 10 分钟
                if elapsed >= STUCK_TIMEOUT:
                    logging.error("条件满足！准备Kill进程并重启训练！")
                    
                    # 1. 杀掉进程
                    kill_gpu_processes()
                    
                    # 等待几秒钟让显存彻底释放
                    time.sleep(5)
                    
                    # 2. 重启训练脚本
                    logging.info(f"正在执行重启命令: {RESTART_CMD}")
                    # 使用 Popen 异步执行，避免阻塞监控脚本
                    subprocess.Popen(RESTART_CMD, shell=True, executable='/bin/bash')
                    
                    # 3. 重置计时器，并休眠一段时间等待模型重新加载（避免马上又被误判）
                    stuck_start_time = None
                    logging.info("重启命令已下发，休眠 5 分钟等待环境初始化...")
                    time.sleep(300) 
        else:
            if stuck_start_time is not None:
                logging.info("GPU 状态恢复正常，计时器已重置。")
                stuck_start_time = None
                
        time.sleep(CHECK_INTERVAL)

if __name__ == "__main__":
    main()